# Example environment configuration for Jarvis

# Language model provider.
# Supported values: "ollama", "openai", "auto" (auto-choose based on environment)
LLM_PROVIDER=ollama

# Name of the Ollama model to use when LLM_PROVIDER=ollama.
# See https://ollama.com/library for available models. For example: llama3.1:8b, qwen2.5:7b-instruct
OLLAMA_MODEL=llama3.1:8b

# Name of the OpenAI model to use when LLM_PROVIDER=openai.
OPENAI_MODEL=gpt-4o

# API key for OpenAI. Required when LLM_PROVIDER=openai or STT_PROVIDER=openai.
OPENAI_API_KEY=

# Optional base URL for OpenAI-compatible API (e.g. OpenRouter or self-hosted proxy)
OPENAI_BASE_URL=

# Speech-to-text provider for processing audio and voice messages.
# Supported values: "vosk", "openai", "auto" (auto-choose based on available models)
STT_PROVIDER=auto

# Directory containing the Vosk offline model. Set this if you want to use
# offline transcription and avoid automatic fallback to OpenAI Whisper when
# STT_PROVIDER=auto. Download a Russian Vosk model from
# https://alphacephei.com/vosk/models and extract here.
VOSK_MODEL_DIR=models/vosk-ru

# Name of the OpenAI Whisper model for speech recognition when STT_PROVIDER=openai.
OPENAI_STT_MODEL=whisper-1

# Path to ffmpeg binary. This is used to convert audio files to mono 16 kHz WAV.
# Leave empty to use the ffmpeg in your PATH. Set a full path if ffmpeg is installed elsewhere.
FFMPEG_BIN=

# Telegram bot token. Obtain from @BotFather and paste here.
TELEGRAM_TOKEN=

# The timezone for your reminders and agenda. Example: Europe/Paris
TIMEZONE=Europe/Paris
